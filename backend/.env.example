# Backend Environment Configuration Template
# ==========================================
# IMPORTANT: Do NOT use quotation marks around values
# Copy this file to .env and fill in your actual values

# ─── Supabase Configuration ───────────────────────────────────────────────────
# Find these in your Supabase project Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# ─── Gemini AI Configuration ─────────────────────────────────────────────────
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── JWT Secret ─────────────────────────────────────────────────────────────
# Generate a secure key with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-secure-32-character-secret

# ─── Clerk Authentication (optional) ───────────────────────────────────────
# For frontend integration with Clerk
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=your-clerk-secret-key-here

# ─── Application Settings ────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
